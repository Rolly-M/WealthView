{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install --legacy-peer-deps",
  "env": {
    "NEXT_PUBLIC_SUPABASE_URL": "@wealthview_supabase_url",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": "@wealthview_supabase_anon_key",
    "SUPABASE_SERVICE_ROLE_KEY": "@wealthview_supabase_service_role_key",
    "ANTHROPIC_API_KEY": "@wealthview_anthropic_api_key",
    "NEXT_PUBLIC_APP_URL": "@wealthview_app_url"
  }
}
