# ============================================================
# WealthView Duo — Environment Configuration
# Copy to .env and fill in your values.
# ============================================================

# --- Database ---
POSTGRES_USER=wealthview
POSTGRES_PASSWORD=wealthview_secret
POSTGRES_DB=wealthview_duo

# --- Redis ---
REDIS_PASSWORD=redis_secret

# --- App Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change_this_to_a_strong_random_secret_key_at_least_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Demo Mode ---
# Set to true for local dev without real bank credentials
DEMO_MODE=true

# --- Plaid (Bank Integration) ---
# Sign up at https://plaid.com/docs/
# TODO: Fill in when moving out of demo mode
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox  # sandbox | development | production

# --- OpenAI (Finance Chat) ---
# TODO: Add your OpenAI API key for the chat assistant
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Email (Invite flow) ---
# TODO: Fill in with your SMTP provider
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@wealthviewduo.com

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# --- Environment ---
ENVIRONMENT=development  # development | staging | production

# --- Feature Flags ---
ENABLE_PLAID=false
ENABLE_OPENAI_CHAT=false
ENABLE_REAL_ETF_DATA=false
